import { createFileRoute } from '@tanstack/react-router'
import { type FormEvent, useState } from 'react'
import { SectionReveal } from '~/components/section-reveal'
import { SiteShell } from '~/components/site-shell'
import { TestimonialCarousel } from '~/components/testimonial-carousel'

const reviews = [
  {
    quote: 'Lost 7 kg and gained confidence through Zumba + HIIT sessions. The environment felt very supportive.',
    name: 'Rhea S.',
    result: 'Women Transformation Journey',
  },
  {
    quote: 'Best women-friendly fitness studio in Pune. Premium vibe and welcoming coaches.',
    name: 'Neha A.',
    result: 'Beginner to Consistent Member',
  },
  {
    quote: 'Yoga + functional training completely improved my posture and daily energy levels.',
    name: 'Priya T.',
    result: 'Yoga & Mobility Flow Program',
  },
  {
    quote: 'Supportive environment, not intimidating like regular gyms. I finally stayed consistent.',
    name: 'Megha V.',
    result: '12-week Lifestyle Fitness Plan',
  },
  {
    quote: 'Great balance of cardio, strength, and mobility. Excellent coaching quality throughout.',
    name: 'Aman G.',
    result: 'Functional Strength Program',
  },
]

type FormState = {
  name: string
  phone: string
  goal: string
  preferredTime: string
}

export const Route = createFileRoute('/contact')({
  head: () => ({
    meta: [
      { title: 'Contact & Free Trial | ONEXFIT Health Club Pune' },
      {
        name: 'description',
        content:
          'Book your free trial at ONEXFIT Health Club. Call, WhatsApp, or submit your details for a response within 10 minutes.',
      },
    ],
  }),
  component: ContactPage,
})

function ContactPage() {
  const [form, setForm] = useState<FormState>({
    name: '',
    phone: '',
    goal: 'HIIT Fat Loss Training',
    preferredTime: '',
  })
  const [error, setError] = useState('')
  const [success, setSuccess] = useState('')

  const onSubmit = (event: FormEvent<HTMLFormElement>) => {
    event.preventDefault()
    setError('')
    setSuccess('')

    if (!form.name.trim() || !form.phone.trim() || !form.preferredTime.trim()) {
      setError('Please complete all fields to book your free trial.')
      return
    }

    const message = encodeURIComponent(
      `Hi, I want to book a free trial at ONEXFIT Health Club.\nName: ${form.name}\nPhone: ${form.phone}\nFitness Goal: ${form.goal}\nPreferred Time: ${form.preferredTime}`,
    )

    setSuccess('Thanks! Redirecting you to WhatsApp to confirm your free trial...')
    window.open(`https://wa.me/919860941818?text=${message}`, '_blank', 'noopener,noreferrer')
  }

  return (
    <SiteShell>
      <section className="relative isolate overflow-hidden border-b border-white/10">
        <div className="absolute inset-0 -z-10">
          <img
            src="https://images.unsplash.com/photo-1534367610501-26bf04f2c947?auto=format&fit=crop&w=2200&q=80"
            alt="Supportive premium fitness onboarding session"
            className="h-full w-full object-cover opacity-34"
          />
          <div className="absolute inset-0 bg-gradient-to-r from-black/88 via-black/72 to-black/84" />
        </div>

        <div className="mx-auto w-full max-w-7xl px-4 py-20 sm:px-6 lg:px-8 lg:py-24">
          <SectionReveal className="max-w-3xl">
            <p className="text-xs tracking-[0.2em] text-[#e4be6a]">CONTACT & FREE TRIAL</p>
            <h1 className="mt-3 text-4xl font-semibold tracking-tight sm:text-5xl">Start your balanced transformation with ONEXFIT.</h1>
            <p className="mt-4 text-white/72">
              Limited free trial slots available every week. Share your details and our team responds within 10 minutes.
            </p>
          </SectionReveal>
        </div>
      </section>

      <section className="mx-auto w-full max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
        <div className="grid gap-7 lg:grid-cols-[1fr_1fr]">
          <SectionReveal className="rounded-2xl border border-white/12 bg-white/[0.04] p-6">
            <p className="text-xs tracking-[0.2em] text-[#e4be6a]">CONTACT INFO</p>
            <h2 className="mt-2 text-3xl font-semibold">ONEXFIT Health Club</h2>
            <p className="mt-4 text-white/75">
              Destination Centre 1, F-55, Nanded City, Sinhagad Road, Pune, Maharashtra 411068, India
            </p>
            <div className="mt-6 space-y-3 text-sm text-white/80">
              <p>
                Phone:{' '}
                <a href="tel:+919860941818" className="text-[#f6d289] hover:underline">
                  +91 9860941818
                </a>
              </p>
              <p>
                Email:{' '}
                <a href="mailto:info@onexfit.com" className="text-[#f6d289] hover:underline">
                  info@onexfit.com
                </a>
              </p>
            </div>

            <div className="mt-7 flex flex-wrap gap-3">
              <a
                href="https://wa.me/919860941818?text=Hi%2C%20I%20want%20to%20book%20a%20free%20trial%20at%20ONEXFIT%20Health%20Club."
                target="_blank"
                rel="noreferrer"
                className="luxury-btn rounded-full px-5 py-2.5 text-sm font-semibold text-black"
              >
                Chat on WhatsApp
              </a>
              <a
                href="tel:+919860941818"
                className="rounded-full border border-white/30 px-5 py-2.5 text-sm transition hover:border-white/70"
              >
                Call Now
              </a>
            </div>

            <p className="mt-4 text-sm text-[#f0cf87]">Limited Free Trial Slots Every Week</p>
          </SectionReveal>

          <SectionReveal delayMs={80} className="rounded-2xl border border-[#e4be6a]/30 bg-gradient-to-br from-[#e4be6a]/10 to-black p-6">
            <p className="text-xs tracking-[0.2em] text-[#e4be6a]">BOOK FREE TRIAL</p>
            <form className="mt-4 grid gap-4" onSubmit={onSubmit}>
              <label className="grid gap-2 text-sm text-white/80">
                Name
                <input
                  value={form.name}
                  onChange={(event) => setForm((current) => ({ ...current, name: event.target.value }))}
                  className="rounded-xl border border-white/20 bg-black/35 px-4 py-3 text-white outline-none transition focus:border-[#e4be6a]/70"
                  placeholder="Your full name"
                />
              </label>

              <label className="grid gap-2 text-sm text-white/80">
                Phone
                <input
                  value={form.phone}
                  onChange={(event) => setForm((current) => ({ ...current, phone: event.target.value }))}
                  className="rounded-xl border border-white/20 bg-black/35 px-4 py-3 text-white outline-none transition focus:border-[#e4be6a]/70"
                  placeholder="+91"
                />
              </label>

              <label className="grid gap-2 text-sm text-white/80">
                Fitness Goal
                <select
                  value={form.goal}
                  onChange={(event) => setForm((current) => ({ ...current, goal: event.target.value }))}
                  className="rounded-xl border border-white/20 bg-black/35 px-4 py-3 text-white outline-none transition focus:border-[#e4be6a]/70"
                >
                  <option>Yoga & Mobility Flow</option>
                  <option>Zumba / Dance Fitness</option>
                  <option>HIIT Fat Loss Training</option>
                  <option>Functional Strength Training</option>
                  <option>Athletic Performance Training</option>
                </select>
              </label>

              <label className="grid gap-2 text-sm text-white/80">
                Preferred Time
                <input
                  value={form.preferredTime}
                  onChange={(event) => setForm((current) => ({ ...current, preferredTime: event.target.value }))}
                  className="rounded-xl border border-white/20 bg-black/35 px-4 py-3 text-white outline-none transition focus:border-[#e4be6a]/70"
                  placeholder="Example: 7:00 AM or 7:30 PM"
                />
              </label>

              {error ? <p className="text-sm text-red-300">{error}</p> : null}
              {success ? <p className="text-sm text-emerald-300">{success}</p> : null}

              <button type="submit" className="luxury-btn rounded-full px-6 py-3 text-sm font-semibold text-black">
                Submit & Continue on WhatsApp
              </button>

              <p className="text-xs text-white/65">We respond within 10 minutes during active hours.</p>
            </form>
          </SectionReveal>
        </div>
      </section>

      <section className="relative isolate overflow-hidden border-y border-white/10 py-16">
        <div className="absolute inset-0 -z-10">
          <img
            src="https://images.unsplash.com/photo-1518611012118-696072aa579a?auto=format&fit=crop&w=2200&q=80"
            alt="Group dance and cardio class at ONEXFIT"
            className="h-full w-full object-cover opacity-20"
          />
          <div className="absolute inset-0 bg-black/78" />
        </div>
        <div className="mx-auto w-full max-w-7xl px-4 sm:px-6 lg:px-8">
          <SectionReveal>
            <p className="text-xs tracking-[0.2em] text-[#e4be6a]">CLIENT RESULTS & REVIEWS</p>
            <h2 className="mt-2 text-3xl font-semibold">Social proof from ONEXFIT members</h2>
            <div className="mt-7">
              <TestimonialCarousel testimonials={reviews} />
            </div>
          </SectionReveal>
        </div>
      </section>

      <section className="mx-auto w-full max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
        <SectionReveal className="overflow-hidden rounded-2xl border border-white/15">
          <iframe
            title="ONEXFIT Health Club Pune Location"
            src="https://www.google.com/maps?q=Destination%20Centre%201%2C%20F-55%2C%20Nanded%20City%2C%20Sinhagad%20Road%2C%20Pune%2C%20Maharashtra%20411068&output=embed"
            className="h-[420px] w-full"
            loading="lazy"
            referrerPolicy="no-referrer-when-downgrade"
          />
        </SectionReveal>
      </section>
    </SiteShell>
  )
}
