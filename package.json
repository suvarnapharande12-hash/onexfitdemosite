import { Link } from '@tanstack/react-router'
import { type ReactNode, useEffect, useState } from 'react'

type SiteShellProps = {
  children: ReactNode
}

const whatsappUrl =
  'https://wa.me/919860941818?text=Hi%2C%20I%20want%20to%20book%20a%20free%20trial%20at%20ONEXFIT%20Health%20Club.'

export function SiteShell({ children }: SiteShellProps) {
  const [progress, setProgress] = useState(0)

  useEffect(() => {
    const onScroll = () => {
      const scrollTop = window.scrollY
      const height = document.documentElement.scrollHeight - window.innerHeight
      const ratio = height > 0 ? Math.min((scrollTop / height) * 100, 100) : 0
      setProgress(ratio)
    }

    onScroll()
    window.addEventListener('scroll', onScroll, { passive: true })
    return () => window.removeEventListener('scroll', onScroll)
  }, [])

  return (
    <div className="relative min-h-screen bg-[#07090c] text-white">
      <div
        aria-hidden="true"
        className="fixed left-0 top-0 z-[70] h-0.5 bg-gradient-to-r from-[#e4be6a] to-[#9d83ff] transition-[width] duration-150"
        style={{ width: `${progress}%` }}
      />

      <div className="fixed inset-0 -z-10 bg-[radial-gradient(circle_at_15%_8%,rgba(228,190,106,0.22),transparent_34%),radial-gradient(circle_at_85%_2%,rgba(115,90,255,0.18),transparent_31%),linear-gradient(180deg,#080b0f_0%,#050607_100%)]" />

      <header className="sticky top-0 z-50 border-b border-white/10 bg-black/50 backdrop-blur-xl">
        <nav className="mx-auto flex w-full max-w-7xl items-center justify-between px-4 py-3.5 sm:px-6 lg:px-8">
          <Link to="/" className="flex items-center gap-2 text-lg font-semibold tracking-[0.2em] text-[#e4be6a]">
            <img
              src="/onexfit-mark.svg"
              alt="ONEXFIT logo"
              className="h-8 w-8 drop-shadow-[0_0_8px_rgba(228,190,106,0.35)] sm:h-9 sm:w-9"
            />
            <span>ONEXFIT</span>
          </Link>
          <div className="hidden items-center gap-6 text-sm text-white/80 md:flex">
            <NavLink to="/">Home</NavLink>
            <NavLink to="/about">About</NavLink>
            <NavLink to="/programs">Programs</NavLink>
            <NavLink to="/trainers">Trainers</NavLink>
            <NavLink to="/contact">Free Trial</NavLink>
          </div>
          <a
            href={whatsappUrl}
            target="_blank"
            rel="noreferrer"
            className="luxury-btn rounded-full px-4 py-2 text-xs font-semibold text-black"
          >
            Chat on WhatsApp
          </a>
        </nav>
      </header>

      {children}

      <footer className="border-t border-white/10 bg-black/40 py-10">
        <div className="mx-auto flex w-full max-w-7xl flex-col gap-6 px-4 sm:px-6 lg:flex-row lg:items-end lg:justify-between lg:px-8">
          <div>
            <img
              src="/onexfit-mark.svg"
              alt="ONEXFIT logo"
              className="h-12 w-12 opacity-90 drop-shadow-[0_0_12px_rgba(228,190,106,0.25)] sm:h-14 sm:w-14"
            />
            <p className="mt-3 text-lg font-semibold tracking-[0.16em] text-[#e4be6a]">ONEXFIT HEALTH CLUB</p>
            <p className="mt-2 max-w-xl text-sm text-white/65">
              Destination Centre 1, F-55, Nanded City, Sinhagad Road, Pune, Maharashtra 411068
            </p>
          </div>
          <div className="space-y-1 text-sm text-white/70">
            <p>
              Phone:{' '}
              <a href="tel:+919860941818" className="text-amber-200 hover:underline">
                +91 9860941818
              </a>
            </p>
            <p>
              Email:{' '}
              <a href="mailto:info@onexfit.com" className="text-amber-200 hover:underline">
                info@onexfit.com
              </a>
            </p>
            <p>
              Instagram:{' '}
              <a href="https://instagram.com/onexfit" target="_blank" rel="noreferrer" className="text-amber-200 hover:underline">
                @onexfit
              </a>
            </p>
          </div>
        </div>
      </footer>

      <a
        href={whatsappUrl}
        target="_blank"
        rel="noreferrer"
        className="fixed bottom-5 right-5 z-50 rounded-full bg-[#25D366] px-5 py-3 text-sm font-semibold text-black shadow-[0_10px_28px_rgba(37,211,102,0.4)] transition hover:scale-105"
      >
        WhatsApp
      </a>
    </div>
  )
}

function NavLink({ children, to }: { children: ReactNode; to: '/' | '/about' | '/programs' | '/trainers' | '/contact' }) {
  return (
    <Link
      to={to}
      activeProps={{ className: 'text-[#f0cf87]' }}
      className="transition hover:text-white"
    >
      {children}
    </Link>
  )
}
